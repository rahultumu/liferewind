{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "app.py" }
  ],
  "excludeFiles": [
    "tests/**",
    "frontend/**",
    "venv/**",
    "*.md",
    ".env",
    "requirements-dev.txt"
  ]
}